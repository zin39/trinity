#!/bin/sh
#
# Pre-commit hook: runs Laravel Pint on staged PHP files.
#

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.php$')

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

if [ ! -x ./vendor/bin/pint ]; then
    echo "WARNING: vendor/bin/pint not found — skipping code style check."
    echo "Run 'composer install' to enable pre-commit linting."
    exit 0
fi

echo "Running Pint on staged PHP files..."

# Run Pint in test mode on staged files only
./vendor/bin/pint --test $STAGED_FILES

if [ $? -ne 0 ]; then
    echo ""
    echo "Code style issues found. Run './vendor/bin/pint' to auto-fix, then re-stage."
    exit 1
fi
