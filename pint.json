{
    "preset": "psr12",
    "rules": {
        "no_unused_imports": true,
        "ordered_imports": {
            "sort_algorithm": "alpha"
        },
        "single_quote": true,
        "trailing_comma_in_multiline": true,
        "array_syntax": {
            "syntax": "short"
        },
        "no_extra_blank_lines": true,
        "blank_line_before_statement": {
            "statements": ["return"]
        }
    },
    "exclude": [
        "vendor",
        "node_modules",
        "storage",
        "bootstrap/cache",
        "public"
    ]
}
